classDiagram
    class Priority {
        <<enumeration>>
        LOW = 1
        MEDIUM = 2
        HIGH = 3
    }

    class Task {
        +UUID id
        +String title
        +String category
        +int duration
        +Priority priority
        +bool completed
        +bool assigned
        +Optional~String~ frequency
        +Optional~date~ due_date
        +mark_complete() Optional~Task~
    }

    class Pet {
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +Optional~Owner~ owner
        +add_task(task: Task) void
        +edit_task(task: Task) void
        +remove_task(task: Task) void
        +complete_task(task: Task) Optional~Task~
        +get_tasks() List~Task~
    }

    class Owner {
        +String name
        +int available_minutes
        +String session_start
        +int session_start_minutes
        +List~String~ preferences
        +List~Pet~ pets
        +add_pet(pet: Pet) void
        +remove_pet(pet: Pet) void
        +get_tasks(completed: Optional~bool~, pet_name: Optional~String~) List~Task~
    }

    class Scheduler {
        +Owner owner
        +build_plan() dict
        +detect_conflicts(scheduled: list) list
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "0..*" --> "0..1" Owner : registered to
    Pet "1" --> "0..*" Task : has
    Task --> Priority : uses
    Scheduler --> Owner : schedules for
